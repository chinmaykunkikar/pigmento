{
  "name": "pigmento",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "Local-first asset cleanup for codebases. Find duplicates, see references, hand cleanup to a coding agent.",
  "bin": {
    "pigmento": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "dev": "next dev -p 9900",
    "build": "next build",
    "build:cli": "node scripts/build-cli.mjs",
    "prepack": "node scripts/build-cli.mjs",
    "start": "next start -p 9900",
    "pigmento": "tsx scripts/pigmento.ts",
    "index": "tsx scripts/pigmento.ts index",
    "index:full": "tsx scripts/pigmento.ts index --full",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "fmt": "biome format --write ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/postcss": "^4.2.4",
    "@tanstack/react-query": "^5.99.2",
    "@tanstack/react-virtual": "^3.13.24",
    "better-sqlite3": "12.9.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "commander": "^14.0.3",
    "culori": "^4.0.2",
    "drizzle-orm": "^0.45.2",
    "fast-glob": "^3.3.3",
    "fuse.js": "^7.3.0",
    "jiti": "^2.6.1",
    "lucide-react": "^1.8.0",
    "next": "16.2.11",
    "p-limit": "^7.3.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sharp": "^0.35.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "xxhash-wasm": "^1.1.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^4.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/better-sqlite3": "^7.6.13",
    "@types/culori": "^4.0.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@10.33.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "sharp",
      "esbuild",
      "onnxruntime-node",
      "protobufjs"
    ],
    "overrides": {
      "esbuild@<0.28.1": ">=0.28.1",
      "protobufjs@<7.6.3": ">=7.6.3",
      "@protobufjs/utf8@<1.1.1": ">=1.1.1",
      "postcss@<8.5.12": ">=8.5.12",
      "adm-zip@<0.6.0": ">=0.6.0",
      "sharp@<0.35.0": ">=0.35.0"
    }
  }
}
